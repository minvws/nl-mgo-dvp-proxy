{
    "name": "mock",
    "dockerComposeFile": [
        "../../docker-compose.yml"
    ],
    "service": "mock",
    "workspaceFolder": "/src/services/nl-mgo-dva-mock-private",
    "shutdownAction": "stopCompose",
    "remoteUser": "app",
    "mounts": [
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.gnupg,target=/home/app/.gnupg,type=bind"
    ],
    "features": {
        "ghcr.io/devcontainers-contrib/features/pre-commit:2": {}
    },
    "initializeCommand": ".devcontainer/init.sh",
    "postCreateCommand": "pre-commit install --install-hooks",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "charliermarsh.ruff",
                "ms-python.mypy-type-checker",
                "EditorConfig.EditorConfig",
                "redhat.vscode-yaml"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.testing.pytestEnabled": true,
                "[python]": {
                    "editor.formatOnSave": true,
                    "editor.defaultFormatter": "charliermarsh.ruff",
                    "editor.codeActionsOnSave": {
                        "source.fixAll.ruff": true,
                        "source.organizeImports.ruff": true
                    }
                }
            }
        }
    }
}
