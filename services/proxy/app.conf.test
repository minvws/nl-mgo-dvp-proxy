[default]
env=testing
base_url=http://localhost:8001/

[metric]
adapter=no-op

[retry]
max_retries=1
backoff=0.25
backoff_factor=1.5

[circuit_breaker]
state_storage=memory

[redis]

[oauth]
client_id = "mgo.medmij@denhaag"
state_signing_key_paths=./secrets/oauth_state_signing_key.key
signature_lifetime_secs=900
auth_redirect_uri=/auth/callback
mock_oauth_servers=true

[dva_target]
jwe_encryption_private_key=./secrets/dva_target/jwe.key
jwt_signing_public_key=./secrets/dva_target/placeholder_jwt_signing.pub

[telemetry]
enabled=False

[oidc]
client_id=7383d3d9-b747-4317-bde2-0e9385d5b9d6
callback_endpoint=/oidc/callback
state_secret_path=secrets/oidc-state.key

[oidc_client_auth]
type=none

[vad_http_client]
url=http://localhost:8006

[forwarding]
require_provider_and_service_id=false
